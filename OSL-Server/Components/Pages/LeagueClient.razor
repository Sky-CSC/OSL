@page "/leagueclient"
@rendermode InteractiveServer
@inject OSL_Server.Services.LeagueClient Watcher
@implements IDisposable

<PageTitle>OSL-Server : League Client</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">League Client
    <MudChip T="string"
             Icon="@GetBooleanIcon(isRunning)"
             Color="@GetBooleanColor(isRunning)"
             Variant="Variant.Filled">
        @GetBooleanText(isRunning)
    </MudChip>
</MudText>
<MudText Class="mb-8">Information about League Client</MudText>

@if (!isRunning)
{
    <MudAlert Severity="Severity.Error">
        Please run your League of Legends application for use OSL-Server and OSL-Overlay
    </MudAlert>
}

<OSL_UI.Box.Build Title="Dev in progress"
                  Text="Display lockfile information : <br/> - Process name <br/> - Process id <br/> - Port <br/> - Key <br/> Display phase in progress" />

@code {
    private bool isRunning;

    protected override void OnInitialized()
    {
        isRunning = Watcher.IsRunning;
        Watcher.OnChange += OnServiceChanged;
    }

    private void OnServiceChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Watcher.OnChange -= OnServiceChanged;
    }

    private static string GetBooleanIcon(bool value) => value
    ? Icons.Material.Filled.PlayCircle
    : Icons.Material.Filled.StopCircle;

    private static Color GetBooleanColor(bool value) => value
        ? Color.Success
        : Color.Error;

    private static string GetBooleanText(bool value) => value
        ? "Running"
        : "Stopped";
}
