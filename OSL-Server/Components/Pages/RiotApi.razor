@page "/riot-api"
@rendermode InteractiveServer
@inject OSL_Server.Services.LeagueClient LeagueClient
@using OSL_Server.Schema
@inject ISnackbar Snackbar


<PageTitle>OSL-Server : Riot Api</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Riot Api</MudText>
<MudText Class="mb-8">Information about <MudLink Href="https://developer.riotgames.com/apis" Target="_blank" Typo="Typo.body2" Color="Color.Primary"> Riot Api </MudLink></MudText>

<OSL_UI.Box.Build Title="Dev in progress"
                  Text="- Display RIOT API key <br/> - Change Riot Api Key <br/> - Restart Riot Api managed in OSL-Server" />

<StyleFieldEditor Label="Riot Game Development Portal Api Key"
                  Type="text"
                  Value="@RiotGameDevelopementPortalConfig.ApiKey"
                  ValueChanged="v => OnStyleChanged(val => RiotGameDevelopementPortalConfig.ApiKey = val, v)"
                  BorderColor="var(--mud-palette-primary)"
                  Placeholder="Your Api Key" />


<MudStack Row="true">
    @* ---------------- Save config ---------------- *@
    <MudButton OnClick="SaveConfig" Variant="Variant.Outlined" Color="Color.Success">
        Save
    </MudButton>
    @* Display if api key is valid or not*@
    @switch (LeagueClient.RiotApiKeyValid)
    {
        case OSL_Server.Services.RiotApiKeyStatus.Valid:
            <MudAlert Severity="Severity.Success">
                Riot Api Key is valid
            </MudAlert>
            break;
        case OSL_Server.Services.RiotApiKeyStatus.Invalid:
            <MudAlert Severity="Severity.Error">
                Riot Api Key is not valid
            </MudAlert>
            break;
        case OSL_Server.Services.RiotApiKeyStatus.NotTested:
            <MudAlert Severity="Severity.Warning">
                Riot Api Key status unknown (Check in <MudLink Href="leagueclient">League Client</MudLink>
            </MudAlert>
            break;
    }
</MudStack>
<br />
<RiotApiStatus PlatformData="@LeagueClient.Status" />

@code {

    private bool isRunning;
    private RiotGameDevelopementPortalConfig RiotGameDevelopementPortalConfig = new RiotGameDevelopementPortalConfig();

    private Action? _handler;

    protected override void OnInitialized()
    {
        RiotGameDevelopementPortalConfig.ApiKey = LeagueClient.GetApiKey();
        _handler = () => InvokeAsync(StateHasChanged);
        LeagueClient.OnChange += _handler;
    }

    public void Dispose()
    {
        if (_handler is not null)
            LeagueClient.OnChange -= _handler;
    }

    private async Task SaveConfig()
    {
        Console.WriteLine("Bordel");
        await LeagueClient.UpdateApiKey(RiotGameDevelopementPortalConfig.ApiKey);
        Snackbar.Add("Riot Api Key updated", Severity.Success);
    }


    /// <summary>
    /// Style changed string
    /// </summary>
    /// <param name="setter"></param>
    /// <param name="newValue"></param>
    private void OnStyleChanged(Action<string> setter, string newValue)
    {
        setter(newValue);
    }
}
