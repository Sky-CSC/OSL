{
  "ApplicationName": "OSL-Server",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Logger": {
    "LogLevel": "INFO"
  },

  "AllowedHosts": "*",

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      },
      "Https": {
        "Url": "https://0.0.0.0:5001"
      }
    }
  },

  "OpenBrowserOnStartup": true,

  "LeagueClientConfig": {
    "LeagueClientProcess": "LeagueClientUX"
  }
}
