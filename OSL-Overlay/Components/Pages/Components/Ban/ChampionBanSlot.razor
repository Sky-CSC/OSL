@using OSL_Overlay.Phase.ChampSelect

@* ---------------- Bans ---------------- *@
<div class="champion">
    @* ---------------- Background image ban ---------------- *@
    <Image Class="champion-ban" ImageUrl="@Ban.BanImage" Background="@Ban.BackgroundColor" Border="@Ban.BorderBanning"/>
    <Image Class="champion-ban" ImageUrl="@Ban.ChampionImage" Border="@Ban.BorderBanning"/>

    @* ---------------- Is Banning ---------------- *@
    @if (Ban.IsBanning)
    {
        <Blink Class="champion-blink" Color="@Ban.BlinkColor" />
    }

    @* ---------------- Cross picture if ban completed ---------------- *@
    @if (Ban.IsCompleted)
    {
        <div class="champion-grey" style="background:@Ban.Greyscale"></div>
        <Image Class="champion-completed-image" ImageUrl="@Ban.Cross.Image" />
        <div class="champion-completed-line" style="color:@Ban.Cross.GraphicLineColor; @Ban.BorderCompleted; --cross-line-width:@Ban.Cross.Width; --cross-line-height:@Ban.Cross.Height; --cross-line-rotate:@Ban.Cross.Rotate" />
        <div class="champion-completed-cross" style="color:@Ban.Cross.GraphicCrossColor; @Ban.BorderCompleted; --cross-line-width:@Ban.Cross.Width; --cross-line-height:@Ban.Cross.Height; --cross-line-rotate:@Ban.Cross.Rotate" />
    }
</div>

@code {
    [Parameter] required public Ban Ban { get; set; }
}
