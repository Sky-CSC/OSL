@code {
    [Parameter] public string Class { get; set; } = string.Empty;
    [Parameter] required public Gold Golds { get; set; }
    private double[] _values = Array.Empty<double>();

    private List<ChartSeries> _series = new();
    private string[] _xLabels = Array.Empty<string>();
    private ChartOptions _options = new();
    private string[] _colors = new[] { "#2196F3", "#000000" }; // bleu (valeurs), noir (ligne zéro)

    protected override void OnInitialized()
    {
        _values = Golds.Events
            .Where(e => e.Type == "Gold")
            .OrderBy(e => e.Timetamps) // facultatif si déjà trié
            .Select(e => (double)e.Value)
            .ToArray();

        BuildChart();
    }

    private void BuildChart()
    {
        int count = _values.Length;
        if (count == 0)
            return;

        // Axe X : progression du temps (0 → 31:40)
        double totalTime = 31 * 60 + 40; // 1900 secondes
        double step = count > 1 ? totalTime / (count - 1) : 0;

        _xLabels = Enumerable.Range(0, count)
            .Select(i =>
            {
                var s = (int)(i * step);
                return $"{s / 60}";
            })
            .ToArray();

        // Crée la série principale (ligne des valeurs)
        var goldSeries = new ChartSeries
        {
            Name = "Gold",
            Data = _values,
            ShowDataMarkers = true
        };

        // Ligne zéro (horizontale)
        double[] zeroLine = Enumerable.Repeat(0.0, count).ToArray();
        var zeroSeries = new ChartSeries
        {
            Name = "Zero",
            Data = zeroLine,
            ShowDataMarkers = false
        };

        _series = new List<ChartSeries> { goldSeries, zeroSeries };

        // ⚙️ Options du graphique
        // _options = new ChartOptions
        // {
        //     LineStrokeWidth = 2,
        //     AnimationDuration = TimeSpan.FromSeconds(1.5), // animation fluide
        //     MaintainAspectRatio = false
        // };
    }
}
