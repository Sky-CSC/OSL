@page "/endgame"
@using OSL_Overlay.GameFlow.EndGame
@inject EndGameState EndGameState


<StyleFieldEditor Label="Match Id"
                  Type="text"
                  Value="@_idMatch"
                  ValueChanged="v => OnStyleChanged(val => _idMatch = val, v)"
                  HelperText="Just Id not region prefix" />

<SwitchButton Icon="@Icons.Material.Filled.AddBox"
              Text="@($"Set match {_idMatch}")"
              OnClick="() => SetIdMatch()"
              BackgroundColor="@Colors.Teal.Darken4"
              HoverBackgroundColor="@Colors.Teal.Darken2"
              TextColor="#ffffff"
              MaxWidth="200px"
              MaxHeight="60px"
              BorderRadius="8px"
              FontSize="16px" />

<select @onchange="OnSelectChange" class="border rounded p-1">
    <option value="">-- Sélectionne une statistique --</option>
    @foreach (var prop in EndGameState.ParticipantProperties)
    {
        <option value="@prop">@prop</option>
    }
</select>

<h3>@EndGameState.Info.ChampionStats.Title.Txt</h3>

<div class="grid grid-cols-2 gap-4 mt-2">
    <div>
        <h4>Blue Team</h4>
        @foreach (var player in EndGameState.Info.ChampionStats.BlueTeam)
        {
            <div>@player.Stat.Txt</div>
        }
    </div>
    <div>
        <h4>Red Team</h4>
        @foreach (var player in EndGameState.Info.ChampionStats.RedTeam)
        {
            <div>@player.Stat.Txt</div>
        }
    </div>
</div>


@code {
    private string _idMatch = "7550999924";

    protected override void OnInitialized()
    {
        EndGameState.OnChange += async () => await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        EndGameState.OnChange -= async () => await InvokeAsync(StateHasChanged);
    }

    private void OnSelectChange(ChangeEventArgs e)
    {
        var selected = e.Value?.ToString();
        if (!string.IsNullOrEmpty(selected))
        {
            EndGameState.UpdateTotalInfo(selected);
            StateHasChanged();
        }
    }

    private void OnStyleChanged(Action<string> setter, string newValue)
    {
        setter(newValue);
        RefreshUI();
    }

    public async Task SetIdMatch()
    {
        await EndGameState.CustomSetMatch(Convert.ToInt64(_idMatch));
        await EndGameState.CustomSetTimeline(Convert.ToInt64(_idMatch));

    }

    private void RefreshUI()
    {
        InvokeAsync(StateHasChanged);
        EndGameState.NotifyStateChanged();
    }
}
