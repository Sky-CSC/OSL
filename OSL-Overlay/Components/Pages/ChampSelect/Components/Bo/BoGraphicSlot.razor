@using OSL_Overlay.Phase.ChampSelect

<div class="bo-graphic @Team">
    @* Display BO *@
    @for (int i = 0; i < Bo.NbMatchForWin; i++)
    {
        if (i < Bo.NbWin)
        {
            <div class="bo-graphic-slot" style="background:@Bo.Win.Color; border:@Bo.Win.Border;"></div>
        }
        else
        {
            <div class="bo-graphic-slot" style="background:@Bo.Undef.Color; border:@Bo.Undef.Border;"></div>
        }
    }
</div>


@code {
    [Parameter] public string Team { get; set; } = string.Empty;
    [Parameter] required public BoGraphic Bo { get; set; }
}
