@page "/champselect/view1/custom"
@using OSL_Overlay.GameFlow.ChampSelect
@inject ChampSelectView1State ViewState

@* ---------------- Champ select View1 management ---------------- *@
<PageTitle>ChampSelect - View1 - Customize</PageTitle>

<style>
    .section {
        scroll-margin-top: 10vh;
    }
</style>

<MudText Typo="Typo.h4" GutterBottom="true" Style="text-decoration-line: underline; font-weight:bold;"><b>Champ Select management</b></MudText>
<br />

@* ---------------- Choose file style to use ---------------- *@
<StyleManager RelativePath="styles/champselect/view1"
              CurrentFile="@ViewState.CurrentFile"
              OnSave="HandleSave"
              OnFileSelected="HandleFileSelected" />
<br />
@* ---------------- Customize field ---------------- *@
<MudStack Row="false" Spacing="3">

    @* ---------------- Background ---------------- *@
    <MudText Id="background" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Background</MudText>
    <StyleFieldEditor Label=""
                      Type="background"
                      Value="@Info.Background"
                      ValueChanged="v => OnStyleChanged(val => Info.Background = val, v)" />
    <br />
    @* ---------------- Picks bakground---------------- *@
    <MudText Id="pick-background" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Picks background</MudText>
    <StyleFieldEditor Label=""
                      Type="background"
                      Value="@Info.TeamsBackground"
                      ValueChanged="v => OnStyleChanged(val => Info.TeamsBackground = val, v)" />
    <br />
    <MudText Id="pick-champion-background" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Pick champion background</MudText>
    @* ---------------- Teams bakground---------------- *@
    <MudStack Row="true">
        @* ---------------- Blue bakground---------------- *@
        <StyleFieldEditor Label="Blue team"
                          Type="background"
                          Value="@Info.BlueTeam.Background"
                          ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Background = val, v)"
                          BorderColor="#0B849E" />
        @* ---------------- Red bakground---------------- *@
        <StyleFieldEditor Label="Red team"
                          Type="background"
                          Value="@Info.RedTeam.Background"
                          ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Background = val, v)"
                          BorderColor="#BE1E37" />

    </MudStack>
    <br />
    @* ---------------- Blink---------------- *@
    <MudText Id="pick-blink" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Pick blink</MudText>
    @* ---------------- Blue blink ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;">
        @for (int i = 0; i < Info.BlueTeam.Picks.Count; i++)
        {
            var index = i;
            @* ---------------- Background ---------------- *@
            <StyleFieldEditor Label="@($"Blue champion {index + 1}")"
                              Type="background"
                              Value="@Info.BlueTeam.Picks[index].BlinkColor"
                              ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Picks[index].BlinkColor = val, v)"
                              BorderColor="#0B849E" />
        }
    </MudStack>
    @* ---------------- Red blink ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;">
        @for (int i = 0; i < Info.RedTeam.Picks.Count; i++)
        {
            var index = i;
            @* ---------------- Background ---------------- *@
            <StyleFieldEditor Label="@($"Red champion {index + 1}")"
                              Type="background"
                              Value="@Info.RedTeam.Picks[index].BlinkColor"
                              ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Picks[index].BlinkColor = val, v)"
                              BorderColor="#BE1E37" />
        }
    </MudStack>
    <br />
    @* ---------------- Champ border ---------------- *@
    <MudText Id="pick-border" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Champion border</MudText>
    @* ---------------- Blue border ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;">
        @for (int i = 0; i < Info.BlueTeam.Picks.Count; i++)
        {
            var index = i;
            @* ---------------- Border ---------------- *@
            <StyleFieldEditor Label="@($"Blue champion {index + 1}")"
                              Type="border"
                              Value="@Info.BlueTeam.Picks[index].BorderImage"
                              ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Picks[index].BorderImage = val, v)"
                              BorderColor="#0B849E" />
        }
    </MudStack>
    @* ---------------- Red border ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;">
        @for (int i = 0; i < Info.RedTeam.Picks.Count; i++)
        {
            var index = i;
            @* ---------------- Border ---------------- *@
            <StyleFieldEditor Label="@($"Red champion {index + 1}")"
                              Type="border"
                              Value="@Info.RedTeam.Picks[index].BorderImage"
                              ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Picks[index].BorderImage = val, v)"
                              BorderColor="#BE1E37" />
        }
    </MudStack>
    <br />
    @* ---------------- Summoner name ---------------- *@
    <MudText Id="summoner-name" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Summoner name</MudText>
    @* ---------------- Blue name ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;">
        @for (int i = 0; i < Info.BlueTeam.Picks.Count; i++)
        {
            var index = i;
            <MudStack Row="false" Spacing="2">
                @* ---------------- Background ---------------- *@
                <StyleFieldEditor Label="@($"Blue summoner name {index + 1} background")"
                                  Type="background"
                                  Value="@Info.BlueTeam.Picks[index].Name.Background"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Picks[index].Name.Background = val, v)"
                                  BorderColor="#0B849E" />
                @* ---------------- Border ---------------- *@
                <StyleFieldEditor Label="@($"Blue summoner name {index + 1} border")"
                                  Type="border"
                                  Value="@Info.BlueTeam.Picks[index].Name.Border"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Picks[index].Name.Border = val, v)"
                                  BorderColor="#0B849E" />
                @* ---------------- Color ---------------- *@
                <StyleFieldEditor Label="@($"Blue summoner name {index + 1} color")"
                                  Type="color"
                                  Value="@Info.BlueTeam.Picks[index].Name.Color"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Picks[index].Name.Color = val, v)"
                                  BorderColor="#0B849E" />
            </MudStack>
        }
    </MudStack>
    @* ---------------- Red name ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;">
        @for (int i = 0; i < Info.RedTeam.Picks.Count; i++)
        {
            var index = i;
            <MudStack Row="false" Spacing="2">
                @* ---------------- Background ---------------- *@
                <StyleFieldEditor Label="@($"Red summoner name {index + 1} background")"
                                  Type="background"
                                  Value="@Info.RedTeam.Picks[index].Name.Background"
                                  ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Picks[index].Name.Background = val, v)"
                                  BorderColor="#BE1E37" />
                @* ---------------- Border ---------------- *@
                <StyleFieldEditor Label="@($"Red summoner name {index + 1} border")"
                                  Type="border"
                                  Value="@Info.RedTeam.Picks[index].Name.Border"
                                  ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Picks[index].Name.Border = val, v)"
                                  BorderColor="#BE1E37" />
                @* ---------------- Color ---------------- *@
                <StyleFieldEditor Label="@($"Red summoner name {index + 1} color")"
                                  Type="color"
                                  Value="@Info.RedTeam.Picks[index].Name.Color"
                                  ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Picks[index].Name.Color = val, v)"
                                  BorderColor="#BE1E37" />
            </MudStack>
        }
    </MudStack>
    <br />
    @* ---------------- Summoner spell ---------------- *@
    <MudText Id="summoner-spell" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Summoner spell</MudText>
    @* ---------------- Blue summoner spell ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;">
        @for (int i = 0; i < Info.BlueTeam.Picks.Count; i++)
        {
            var index = i;
            @* ---------------- Show summoner spell ? ---------------- *@
            <StyleFieldEditor Label="Show blue summoner spell ?"
                              Type="checkbox"
                              Value="@Info.BlueTeam.Picks[index].ShowSummonerSpells.ToString()"
                              ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Picks[index].ShowSummonerSpells = val, v)"
                              BorderColor="#0B849E" />
        }
    </MudStack>
    @* ---------------- Red summoner spell ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;">
        @for (int i = 0; i < Info.RedTeam.Picks.Count; i++)
        {
            var index = i;
            @* ---------------- Show summoner spell ? ---------------- *@
            <StyleFieldEditor Label="Show blue summoner spell ?"
                              Type="checkbox"
                              Value="@Info.RedTeam.Picks[index].ShowSummonerSpells.ToString()"
                              ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Picks[index].ShowSummonerSpells = val, v)"
                              BorderColor="#BE1E37" />
        }
    </MudStack>
    <br />
    @* ---------------- Lanes ---------------- *@
    <MudText Id="lane" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Lane</MudText>
    @* ---------------- Blue Lanes ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;">
        @for (int i = 0; i < Info.BlueTeam.Picks.Count; i++)
        {
            var index = i;
            var path = "assets/positions/top";
            if (index == 1)
                path = "assets/positions/jungle";
            else if (index == 2)
                path = "assets/positions/mid";
            else if (index == 3)
                path = "assets/positions/adc";
            else if (index == 4)
                path = "assets/positions/support";
            <MudStack Row="false" Style="overflow-y:auto;">
                @* ---------------- Show lane ? ---------------- *@
                <StyleFieldEditor Label="Show lane image ?"
                                  Type="checkbox"
                                  Value="@Info.BlueTeam.Picks[index].ShowLane.ToString()"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Picks[index].ShowLane = val, v)"
                                  BorderColor="#0B849E" />
                @* ---------------- Lane image ---------------- *@
                <StyleFieldEditor Label="@($"Blue player {index + 1} lane")"
                                  Type="image"
                                  Value="@Info.BlueTeam.Picks[index].LaneImage"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Picks[index].LaneImage = val, v)"
                                  DirectoryPath="@path"
                                  BorderColor="#0B849E" />
            </MudStack>
        }
    </MudStack>
    @* ---------------- Red Lanes ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;">
        @for (int i = 0; i < Info.RedTeam.Picks.Count; i++)
        {
            var index = i;
            var path = "assets/positions/top";
            if (index == 1)
                path = "assets/positions/jungle";
            else if (index == 2)
                path = "assets/positions/mid";
            else if (index == 3)
                path = "assets/positions/adc";
            else if (index == 4)
                path = "assets/positions/support";
            <MudStack Row="false" Style="overflow-y:auto;">
                @* ---------------- Show lane ? ---------------- *@
                <StyleFieldEditor Label="Show lane image ?"
                                  Type="checkbox"
                                  Value="@Info.RedTeam.Picks[index].ShowLane.ToString()"
                                  ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Picks[index].ShowLane = val, v)"
                                  BorderColor="#BE1E37" />
                @* ---------------- Lane image ---------------- *@
                <StyleFieldEditor Label="@($"Red player {index + 1} lane")"
                                  Type="image"
                                  Value="@Info.RedTeam.Picks[index].LaneImage"
                                  ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Picks[index].LaneImage = val, v)"
                                  DirectoryPath="@path"
                                  BorderColor="#BE1E37" />
            </MudStack>
        }
    </MudStack>
    <br />
    @* ---------------- Timer ---------------- *@
    <MudText Id="timer" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Timer</MudText>
    @* ---------------- Blue Timer ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;" AlignItems="AlignItems.Center">
        @* ---------------- Background ---------------- *@
        <StyleFieldEditor Label="Blue background"
                          Type="background"
                          Value="@Info.BlueTeam.Timer.BarColor"
                          ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Timer.BarColor = val, v)"
                          BorderColor="#0B849E" />
        @* ---------------- Fill color ---------------- *@
        <StyleFieldEditor Label="Blue fill"
                          Type="background"
                          Value="@Info.BlueTeam.Timer.FillColor"
                          ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Timer.FillColor = val, v)"
                          BorderColor="#0B849E" />
        @* ---------------- Direction ---------------- *@
        <StyleFieldEditor Label="Blue direction"
                          Type="timer"
                          Value="@Info.BlueTeam.Timer.Direction"
                          ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Timer.Direction = val, v)"
                          BorderColor="#0B849E" />
    </MudStack>
    @* ---------------- Red Timer ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;" AlignItems="AlignItems.Center">
        @* ---------------- Background ---------------- *@
        <StyleFieldEditor Label="Red background"
                          Type="background"
                          Value="@Info.RedTeam.Timer.BarColor"
                          ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Timer.BarColor = val, v)"
                          BorderColor="#BE1E37" />
        @* ---------------- Fill color ---------------- *@
        <StyleFieldEditor Label="Red fill"
                          Type="background"
                          Value="@Info.RedTeam.Timer.FillColor"
                          ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Timer.FillColor = val, v)"
                          BorderColor="#BE1E37" />
        @* ---------------- Direction ---------------- *@
        <StyleFieldEditor Label="Red direction"
                          Type="timer"
                          Value="@Info.RedTeam.Timer.Direction"
                          ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Timer.Direction = val, v)"
                          BorderColor="#BE1E37" />
    </MudStack>
    @* ---------------- Common Timer ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;" AlignItems="AlignItems.Center">
        @* ---------------- Background ---------------- *@
        <StyleFieldEditor Label="Common background"
                          Type="background"
                          Value="@Info.CommonTimer.BarColor"
                          ValueChanged="v => OnStyleChanged(val => Info.CommonTimer.BarColor = val, v)" />
        @* ---------------- Fill color ---------------- *@
        <StyleFieldEditor Label="Common fill"
                          Type="background"
                          Value="@Info.CommonTimer.FillColor"
                          ValueChanged="v => OnStyleChanged(val => Info.CommonTimer.FillColor = val, v)" />
        @* ---------------- Direction ---------------- *@
        <StyleFieldEditor Label="Common direction"
                          Type="timer"
                          Value="@Info.CommonTimer.Direction"
                          ValueChanged="v => OnStyleChanged(val => Info.CommonTimer.Direction = val, v)" />
    </MudStack>
    <br />
    @* ---------------- Patch ---------------- *@
    <MudText Id="patch" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Patch</MudText>
    <MudStack Row="true" Style="overflow-y:auto;" AlignItems="AlignItems.Center">
        <MudStack Row="false">
            @* ---------------- Show patch ? ---------------- *@
            <StyleFieldEditor Label="Show patch ?"
                              Type="checkbox"
                              Value="@Info.Patch.Show.ToString()"
                              ValueChanged="v => OnStyleChanged(val => Info.Patch.Show = val, v)" />
            @* ---------------- Background ---------------- *@
            <StyleFieldEditor Label="Background"
                              Type="background"
                              Value="@Info.Patch.BackgroundColor"
                              ValueChanged="v => OnStyleChanged(val => Info.Patch.BackgroundColor = val, v)" />
        </MudStack>
        @* ---------------- Border ---------------- *@
        <StyleFieldEditor Label="Border"
                          Type="border"
                          Value="@Info.Patch.BorderColor"
                          ValueChanged="v => OnStyleChanged(val => Info.Patch.BorderColor = val, v)" />
        @* ---------------- Patch Text ---------------- *@
        <MudStack Row="false">
            @* ---------------- Color ---------------- *@
            <StyleFieldEditor Label="Patch color"
                              Type="color"
                              Value="@Info.Patch.PatchInfo.Color"
                              ValueChanged="v => OnStyleChanged(val => Info.Patch.PatchInfo.Color = val, v)" />
            @* ---------------- Font ---------------- *@
            <StyleFieldEditor Label="Patch font"
                              Type="font"
                              Value="@Info.Patch.PatchInfo.Font"
                              ValueChanged="v => OnStyleChanged(val => Info.Patch.PatchInfo.Font = val, v)" />
        </MudStack>
        @* ---------------- Version Text ---------------- *@
        <MudStack Row="false">
            @* ---------------- Color ---------------- *@
            <StyleFieldEditor Label="Version color"
                              Type="color"
                              Value="@Info.Patch.Version.Color"
                              ValueChanged="v => OnStyleChanged(val => Info.Patch.Version.Color = val, v)" />
            @* ---------------- Font ---------------- *@
            <StyleFieldEditor Label="Version font"
                              Type="font"
                              Value="@Info.Patch.Version.Font"
                              ValueChanged="v => OnStyleChanged(val => Info.Patch.Version.Font = val, v)" />
        </MudStack>
    </MudStack>
    <br />
    @* ---------------- Coach ---------------- *@
    <MudText Id="coach" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Coach</MudText>
    <MudStack Row="true" Style="overflow-y:auto;" AlignItems="AlignItems.Center">
        @* ---------------- Blue Coach ---------------- *@
        <MudStack Row="false">
            @* ---------------- Show coach ? ---------------- *@
            <StyleFieldEditor Label="Show blue coach ?"
                              Type="checkbox"
                              Value="@Info.BlueTeam.Coach.Show.ToString()"
                              ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Coach.Show = val, v)"
                              BorderColor="#0B849E" />
            @* ---------------- Background ---------------- *@
            <StyleFieldEditor Label="Blue background"
                              Type="background"
                              Value="@Info.BlueTeam.Coach.Background"
                              ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Coach.Background = val, v)"
                              BorderColor="#0B849E" />
        </MudStack>
        @* ---------------- Border ---------------- *@
        <StyleFieldEditor Label="Blue border"
                          Type="border"
                          Value="@Info.BlueTeam.Coach.Border"
                          ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Coach.Border = val, v)"
                          BorderColor="#0B849E" />
        <MudStack Row="false">
            @* ---------------- Text color ---------------- *@
            <StyleFieldEditor Label="Blue text color"
                              Type="color"
                              Value="@Info.BlueTeam.Coach.Text.Color"
                              ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Coach.Text.Color =val, v)"
                              BorderColor="#0B849E" />
            @* ---------------- Text font ---------------- *@
            <StyleFieldEditor Label="Blue text font"
                              Type="font"
                              Value="@Info.BlueTeam.Coach.Text.Font"
                              ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Coach.Text.Font =val, v)"
                              BorderColor="#0B849E" />
        </MudStack>
        <MudStack Row="false">
            @* ---------------- Name color ---------------- *@
            <StyleFieldEditor Label="Blue name color"
                              Type="color"
                              Value="@Info.BlueTeam.Coach.Name.Color"
                              ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Coach.Name.Color =val, v)"
                              BorderColor="#0B849E" />
            @* ---------------- Name font ---------------- *@
            <StyleFieldEditor Label="Blue name font"
                              Type="font"
                              Value="@Info.BlueTeam.Coach.Name.Font"
                              ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Coach.Name.Font =val, v)"
                              BorderColor="#0B849E" />
        </MudStack>
    </MudStack>
    @* ---------------- Red Coach ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;">
        <MudStack Row="false">
            @* ---------------- Show coach ---------------- *@
            <StyleFieldEditor Label="Show red coach ?"
                              Type="checkbox"
                              Value="@Info.RedTeam.Coach.Show.ToString()"
                              ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Coach.Show = val, v)"
                              BorderColor="#BE1E37" />
            @* ---------------- Background ---------------- *@
            <StyleFieldEditor Label="Red background"
                              Type="background"
                              Value="@Info.RedTeam.Coach.Background"
                              ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Coach.Background = val, v)"
                              BorderColor="#BE1E37" />
        </MudStack>
        @* ---------------- Border ---------------- *@
        <StyleFieldEditor Label="Red border"
                          Type="border"
                          Value="@Info.RedTeam.Coach.Border"
                          ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Coach.Border = val, v)"
                          BorderColor="#BE1E37" />
        <MudStack Row="false">
            @* ---------------- Text color ---------------- *@
            <StyleFieldEditor Label="Red text color"
                              Type="color"
                              Value="@Info.RedTeam.Coach.Text.Color"
                              ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Coach.Text.Color =val, v)"
                              BorderColor="#BE1E37" />
            @* ---------------- Text font ---------------- *@
            <StyleFieldEditor Label="Red text font"
                              Type="font"
                              Value="@Info.RedTeam.Coach.Text.Font"
                              ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Coach.Text.Font =val, v)"
                              BorderColor="#BE1E37" />
        </MudStack>
        <MudStack Row="false">
            @* ---------------- Name color ---------------- *@
            <StyleFieldEditor Label="Red name color"
                              Type="color"
                              Value="@Info.RedTeam.Coach.Name.Color"
                              ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Coach.Name.Color =val, v)"
                              BorderColor="#BE1E37" />
            @* ---------------- Name font ---------------- *@
            <StyleFieldEditor Label="Red name font"
                              Type="font"
                              Value="@Info.RedTeam.Coach.Name.Font"
                              ValueChanged="v => OnStyleChanged(val => Info.RedTeam.Coach.Name.Font =val, v)"
                              BorderColor="#BE1E37" />
        </MudStack>
    </MudStack>

    <br />
    @* ---------------- Bans ---------------- *@
    <MudText Id="ban" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Bans</MudText>
    @* ---------------- Blue Bans ---------------- *@
    <MudStack Row="true" Style="overflow-y:auto;">
        @for (int i = 0; i < Info.BlueTeam.Bans.Count; i++)
        {
            var index = i;
            <MudStack Row="false" Spacing="2">
                @* ---------------- Background ---------------- *@
                <StyleFieldEditor Label="@($"Blue ban {index + 1} background")"
                                  Type="background"
                                  Value="@Info.BlueTeam.Bans[index].BackgroundColor"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Bans[index].BackgroundColor = val, v)"
                                  BorderColor="#0B849E" />
                @* ---------------- Image ---------------- *@
                <StyleFieldEditor Label="@($"Blue ban {index + 1} image")"
                                  Type="image"
                                  DirectoryPath="assets/bans"
                                  Value="@Info.BlueTeam.Bans[index].BanImage"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Bans[index].BanImage = val, v)"
                                  BorderColor="#0B849E" />
                @* ---------------- Border banning ---------------- *@
                <StyleFieldEditor Label="@($"Blue ban {index + 1} border banning")"
                                  Type="border"
                                  Value="@Info.BlueTeam.Bans[index].BorderBanning"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Bans[index].BorderBanning = val, v)"
                                  BorderColor="#0B849E" />
                @* ---------------- Border complete ---------------- *@
                <StyleFieldEditor Label="@($"Blue ban {index + 1} border complete")"
                                  Type="border"
                                  Value="@Info.BlueTeam.Bans[index].BorderCompleted"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Bans[index].BorderCompleted = val, v)"
                                  BorderColor="#0B849E" />
                @* ---------------- Blink ---------------- *@
                <StyleFieldEditor Label="@($"Blue ban {index + 1} blink")"
                                  Type="background"
                                  Value="@Info.BlueTeam.Bans[index].BlinkColor"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Bans[index].BlinkColor = val, v)"
                                  BorderColor="#0B849E" />
                @* ---------------- Grey scale ---------------- *@
                <StyleFieldEditor Label="@($"Blue ban {index + 1} grey scale")"
                                  Type="background"
                                  Value="@Info.BlueTeam.Bans[index].Greyscale"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Bans[index].Greyscale = val, v)"
                                  BorderColor="#0B849E" />
                @* ---------------- Color line ban ---------------- *@
                <StyleFieldEditor Label="@($"Blue ban {index + 1} cross image")"
                                  Type="image"
                                  DirectoryPath="assets/bans"
                                  Value="@Info.BlueTeam.Bans[index].Cross.Image.Path"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Bans[index].Cross.Image.Path = val, v)"
                                  BorderColor="#0B849E" />
                @* ---------------- Color line ban ---------------- *@
                <StyleFieldEditor Label="@($"Blue ban {index + 1} line color")"
                                  Type="color"
                                  Value="@Info.BlueTeam.Bans[index].Cross.GraphicLineColor"
                                  ValueChanged="v => OnStyleChanged(val => Info.BlueTeam.Bans[index].Cross.GraphicLineColor = val, v)"
                                  BorderColor="#0B849E" />
                @* ---------------- Color cross ban ---------------- *@
                <StyleFieldEditor Label="@($"Blue ban {index + 1} cross color")"
                                  Type="color"
