@code {
    private ChampSelectInfo Info => ViewState.LocalInfo;

    /// <summary>
    /// When css is update notifie Champ state
    /// </summary>
    /// <param name="setter"></param>
    /// <param name="newValue"></param>
    private void OnStyleChanged(Action<string> setter, string newValue)
    {
        setter(newValue);
        RefreshUI();
    }

    /// <summary>
    /// When css is update notifie Champ state
    /// </summary>
    /// <param name="setter"></param>
    /// <param name="newValue"></param>
    private void OnStyleChanged(Action<bool> setter, string newValue)
    {
        setter(Convert.ToBoolean(newValue));
        RefreshUI();
    }

    private void RefreshUI()
    {
        InvokeAsync(StateHasChanged);
        ViewState.NotifyStateChanged();
    }

    protected override void OnInitialized()
    {
        ViewState.OnChange += async () => await InvokeAsync(StateHasChanged);
        ViewState.SyncFromGlobal();
    }

    public void Dispose()
    {
        ViewState.OnChange -= async () => await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Save file
    /// </summary>
    /// <param name="filePath"></param>
    /// <returns></returns>
    private async Task HandleSave(string filePath)
    {
        // Sauvegarde dans un NOUVEAU fichier
        ViewState.SaveStyle(filePath);
        ViewState.CurrentFile = filePath;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Select file
    /// </summary>
    /// <param name="filePath"></param>
    /// <returns></returns>
    private async Task HandleFileSelected(string filePath)
    {
        // Chargement du style existant
        ViewState.LoadStyle(filePath);
        ViewState.CurrentFile = filePath;
        await InvokeAsync(StateHasChanged);
    }

}
