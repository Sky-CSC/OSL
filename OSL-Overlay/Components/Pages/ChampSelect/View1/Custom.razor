@code {
    // Champ select information css, text and assets path
    private ChampSelectInfo Info => ChampSelectState.Info;

    // Current file used
    private string? _currentFile;

    protected override void OnInitialized()
    {
        _currentFile = ChampSelectState.FileStyle;
    }

    /// <summary>
    /// When css is update notifie Champ state
    /// </summary>
    /// <param name="setter"></param>
    /// <param name="newValue"></param>
    private void OnStyleChanged(Action<string> setter, string newValue)
    {
        setter(newValue);
        ChampSelectState.CssChange();
    }

    /// <summary>
    /// When css is update notifie Champ state
    /// </summary>
    /// <param name="setter"></param>
    /// <param name="newValue"></param>
    private void OnStyleChanged(Action<bool> setter, string newValue)
    {
        setter(Convert.ToBoolean(newValue));
        ChampSelectState.CssChange();
    }

    /// <summary>
    /// Save file
    /// </summary>
    /// <param name="filePath"></param>
    /// <returns></returns>
    private async Task HandleSave(string filePath)
    {
        // Sauvegarde dans un NOUVEAU fichier
        ChampSelectState.SaveStyle(filePath);
        _currentFile = filePath;
        ChampSelectState.FileStyle = _currentFile;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Select file
    /// </summary>
    /// <param name="filePath"></param>
    /// <returns></returns>
    private async Task HandleFileSelected(string filePath)
    {
        // Chargement du style existant
        ChampSelectState.LoadStyle(filePath);
        _currentFile = filePath;
        ChampSelectState.FileStyle = _currentFile;
        await InvokeAsync(StateHasChanged);
    }

}
