@using MudBlazor
@inject IDialogService DialogService
@inject IWebHostEnvironment Env

@* ---------------- Style manager ---------------- *@
<MudPaper Class="pa-4" Style="max-height:400px; overflow-y:auto;">

    @* ---------------- Button for save on new file changes ---------------- *@
    <MudButton Color="Color.Primary"
               Variant="Variant.Filled"
               OnClick="SaveFile"
               Style="@($"color:{Colors.LightGreen.Accent3}; background:{Colors.BlueGray.Darken4};")">
        Save style on new file
    </MudButton>

    <MudDivider Class="my-4" />

    @* ---------------- Tables of files ---------------- *@
    <MudTable Items="_files" Hover="true" Dense="true" Bordered="false" Class="flex-grow-1">
        <RowTemplate>
            <MudTr Style="@GetRowBackgroundStyle(context)">
                <MudTd Style="@GetRowColorStyle(context)" DataLabel="Name">@context</MudTd>

                <MudTd>
                    @* Text for rename file *@
                    <MudTextField T="string"
                                  Value="@GetFileRename(context)"
                                  Placeholder="New name"
                                  Immediate="true"
                                  ValueChanged="@(newValue => UpdateFileRename(context, newValue))" />

                    @* Button for rename file *@
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Style="@($"color:{Colors.Orange.Default};")"
                                   OnClick="@(() => RenameFile(context))" />

                    @* Button for delete file *@
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Style="@($"color:{Colors.Red.Darken4};")"
                                   OnClick="@(() => ConfirmDelete(context))" />

                    @* Button for select file *@
                    <MudButton Style="@($"color:{Colors.Teal.Lighten5}; background:{Colors.Teal.Darken4}")"
                               Variant="Variant.Filled"
                               OnClick="@(() => SelectFile(context))">
                        @(IsSelected(context) ? "Selected" : "Select")
                    </MudButton>

                    @* Button for duplicate file *@
                    <MudButton Style="@($"color:{Colors.Blue.Lighten5}; background:{Colors.Blue.Darken4}")"
                               Variant="Variant.Filled"
                               OnClick="@(() => DuplicateFile(context))">
                        Duplicate
                    </MudButton>

                    @* Button for save changes on file *@
                    <MudButton Style="@($"color:{Colors.LightGreen.Accent3}; background:{Colors.BlueGray.Darken4};")"
                               Variant="Variant.Filled"
                               OnClick="@(() => SaveChanges(context))">
                        Save Changes
                    </MudButton>
                </MudTd>
            </MudTr>
        </RowTemplate>
    </MudTable>
</MudPaper>
