                              ValueChanged="v => OnStyleChanged(val => TeamState.BlueInfo.Logo = val, v)"
                              BorderColor="#0B849E" />
            @if (TeamState.BlueInfo.Logo != "")
            {
                <div style="width:100px; height:105px">
                    <img src="@TeamState.BlueInfo.Logo" alt="@TeamState.BlueInfo.Logo" style="height:100%; border-radius:4px;" />
                </div>
            }
        </MudStack>
        <MudStack Row="true">
            @* ---------------- Blue team custom names ---------------- *@
            <StyleFieldEditor Label="Show all custom name"
                              Type="checkbox"
                              Value="@TeamState.DisplayBlueCustomName.ToString()"
