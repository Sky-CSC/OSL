@page "/team/"
@using OSL_Overlay.GameFlow.Team
@inject TeamState TeamState

@* ---------------- Team managament ---------------- *@
<PageTitle>Team</PageTitle>

<style>
    .section {
        scroll-margin-top: 10vh;
    }
</style>

<MudText Typo="Typo.h4" GutterBottom="true" Style="text-decoration-line: underline; font-weight:bold;"><b>Team management</b></MudText>

<MudStack Row="true">
    @* ---------------- Save blue team info ---------------- *@
    <StyleManager Label="Save config (default for blue)"
                  RelativePath="data/teams"
                  CurrentFile="@TeamState.BlueFile"
                  OnSave="TeamState.SaveBlue"
                  OnFileSelected="TeamState.FileSelectedBlue"
                  HideDuplicate=true
                  FilePrefix="team" />
    <br />
    @* ---------------- Save red team info ---------------- *@
    <StyleManager Label="Save config (default for red)"
                  RelativePath="data/teams"
                  CurrentFile="@TeamState.RedFile"
                  OnSave="TeamState.SaveRed"
                  OnFileSelected="TeamState.FileSelectedRed"
                  HideDuplicate=true
                  FilePrefix="team" />
</MudStack>
<br />
<br />

@* ---------------- Team swap ---------------- *@
<SwitchButton Text="Swap Teams"
              Icon="@Icons.Material.Filled.SwapHoriz"
              BackgroundColor="@Colors.BlueGray.Darken4"
              HoverBackgroundColor="@Colors.Red.Darken2"
              TextColor="#ffffff"
              OnClick="@TeamState.SwapTeams" />
<br />

<MudStack Row="true" Spacing="20">
    <MudStack Row="false">
        @* ---------------- Blue team ---------------- *@
        <MudText Id="blue-side" Class="section" Typo="Typo.h6" Style="text-decoration-line: underline; font-weight:bold;">Blue Team</MudText>
        <MudStack Row="true">
            @* ---------------- Blue team name ---------------- *@
            <StyleFieldEditor Label="Name"
                              Type="text"
                              Value="@TeamState.BlueInfo.Name"
                              ValueChanged="v => OnStyleChanged(val => TeamState.BlueInfo.Name = val, v)"
                              BorderColor="#0B849E" />
            @* ---------------- Blue team tag ---------------- *@
            <StyleFieldEditor Label="Tag"
                              Type="text"
                              Value="@TeamState.BlueInfo.Tag"
                              ValueChanged="v => OnStyleChanged(val => TeamState.BlueInfo.Tag = val, v)"
