@using System.Text.RegularExpressions

<div class="doc-box doc-build">
    <b>🚧 @Title</b><br>

    @foreach (var ligne in ParseBr(Text))
    {
        <div>@ligne</div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "Build";
    [Parameter] public string Text { get; set; } = "Text ...";

    private static List<string> ParseBr(string? texte)
    {
        if (string.IsNullOrWhiteSpace(texte))
            return new();

        return Regex.Split(texte, @"<br\s*/?>", RegexOptions.IgnoreCase)
                    .Where(l => !string.IsNullOrWhiteSpace(l))
                    .ToList();
    }
}
